rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() { return request.auth != null; }

    match /loanInquiries/{id} {
      allow create: if request.auth == null
        && request.resource.data.keys().hasOnly(['channel','name','phone','amount','status','read','memo','createdAt','updatedAt'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 40
        && request.resource.data.phone is string && request.resource.data.phone.size() <= 30
        && request.resource.data.status == '신규'
        && request.resource.data.read == false;
      allow read, update, delete: if isAdmin();
    }

    match /chatRooms/{roomId} {
      allow create: if request.auth == null && request.resource.data.sessionId == roomId;
      allow read: if isAdmin() || resource.data.sessionId == roomId;
      allow update: if isAdmin() || (request.auth == null && resource.data.sessionId == roomId && request.resource.data.sessionId == roomId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow create: if isAdmin() || (request.auth == null
          && get(/databases/$(database)/documents/chatRooms/$(roomId)).data.sessionId == roomId
          && request.resource.data.sender == 'user');
        allow read: if isAdmin() || get(/databases/$(database)/documents/chatRooms/$(roomId)).data.sessionId == roomId;
        allow update, delete: if isAdmin();
      }
    }
  }
}
