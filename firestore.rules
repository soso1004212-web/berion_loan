rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'admin@berionloan.kr';
    }

    // 대출 상담 신청 내역
    match /loanInquiries/{inquiryId} {
      // 방문자는 신규 신청서 작성만 가능
      allow create: if request.auth == null
        && request.resource.data.keys().hasOnly([
          'channel',
          'name',
          'phone',
          'amount',
          'status',
          'read',
          'memo',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 9
        && request.resource.data.phone.size() <= 30
        && request.resource.data.amount is string
        && request.resource.data.amount.size() > 0
        && request.resource.data.amount.size() <= 30
        && request.resource.data.status == '신규'
        && request.resource.data.read == false
        && request.resource.data.memo == '';

      // 관리자만 조회·수정·삭제 가능
      allow read, update, delete: if isAdmin();
    }

    // 실시간 상담방
    match /chatRooms/{roomId} {
      // 방문자는 자신의 세션 ID와 같은 상담방만 생성 가능
      allow create: if request.auth == null
        && request.resource.data.sessionId is string
        && request.resource.data.sessionId == roomId;

      // 관리자 또는 해당 세션의 방문자만 조회 가능
      allow read: if isAdmin()
        || resource.data.sessionId == roomId;

      // 관리자는 전체 수정 가능
      // 방문자는 sessionId를 변경하지 않는 범위에서만 수정 가능
      allow update: if isAdmin()
        || (
          request.auth == null
          && resource.data.sessionId == roomId
          && request.resource.data.sessionId == roomId
        );

      // 상담방 삭제는 관리자만 가능
      allow delete: if isAdmin();

      // 상담 메시지
      match /messages/{messageId} {
        // 관리자는 답변 가능
        // 방문자는 자신의 상담방에 user 메시지만 작성 가능
        allow create: if isAdmin()
          || (
            request.auth == null
            && get(
              /databases/$(database)/documents/chatRooms/$(roomId)
            ).data.sessionId == roomId
            && request.resource.data.sender == 'user'
          );

        // 관리자 또는 해당 상담방 방문자만 메시지 조회 가능
        allow read: if isAdmin()
          || get(
            /databases/$(database)/documents/chatRooms/$(roomId)
          ).data.sessionId == roomId;

        // 메시지 수정·삭제는 관리자만 가능
        allow update, delete: if isAdmin();
      }
    }

    // 위에서 허용한 컬렉션 외에는 모두 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
